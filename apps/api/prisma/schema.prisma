datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SECRETARIAT
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
  ARCHIVED
}

enum Material {
  OR_18K
  OR_24K
  ARGENT_925
  BRONZE
}

enum OrderStatus {
  RECUE
  EN_FABRICATION
  CONTROLE_QUALITE
  LIVREE
  ANNULEE
}

enum NegotiationStatus {
  AUCUNE
  AUTO_VALIDEE
  EN_ATTENTE
  VALIDEE
  REJETEE
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  passwordHash        String
  name                String
  role                Role
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  ordersHandled       Order[]       @relation("OrderHandledBy")
  negotiationsCreated Negotiation[] @relation("NegotiationCreatedBy")
  negotiationsDecided Negotiation[] @relation("NegotiationDecidedBy")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  bannerUrl   String?
  icon        String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  slug        String   @unique
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // --- Les 3 prix : prixMax (public) et prixMin (jamais exposé publiquement) ---
  prixMax Decimal @db.Decimal(12, 2)
  prixMin Decimal @db.Decimal(12, 2)

  material           Material
  weightApproxG      Decimal?       @db.Decimal(8, 2)
  stone              String?
  setting            String?
  hallmark           String?
  sizeOptions        String[]
  colorOptions       String[]
  engravingAvailable Boolean        @default(false)
  deliveryDelay      String?
  warranty           String?
  stock              Int            @default(0)
  status             ProductStatus  @default(DRAFT)
  badges             String[]
  isFeatured         Boolean        @default(false)
  images             ProductImage[]
  orderItems         OrderItem[]
  createdAt          DateTime       @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model Order {
  id              String   @id @default(cuid())
  reference       String   @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  deliveryCity    String
  deliveryNotes   String?
  remarks         String?

  status         OrderStatus @default(RECUE)
  totalCatalogue Decimal     @db.Decimal(12, 2)
  totalReal      Decimal?    @db.Decimal(12, 2)
  deliveryFee    Decimal?    @db.Decimal(12, 2)

  handledById String?
  handledBy   User?   @relation("OrderHandledBy", fields: [handledById], references: [id])

  items        OrderItem[]
  negotiations Negotiation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reference])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productNameSnap String
  variantSize     String?
  variantColor    String?
  engravingText   String?
  quantity        Int     @default(1)

  prixCatalogueSnap Decimal  @db.Decimal(12, 2)
  prixMinSnap       Decimal  @db.Decimal(12, 2)
  prixReelUnitaire  Decimal? @db.Decimal(12, 2)

  negotiations Negotiation[]
}

model Negotiation {
  id          String  @id @default(cuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])

  prixCatalogue Decimal @db.Decimal(12, 2)
  prixMin       Decimal @db.Decimal(12, 2)
  prixPropose   Decimal @db.Decimal(12, 2)
  ecart         Decimal @db.Decimal(12, 2)

  proofImageUrl String?
  reason        String?

  status           NegotiationStatus @default(AUCUNE)
  requiresApproval Boolean           @default(false)

  createdById String
  createdBy   User   @relation("NegotiationCreatedBy", fields: [createdById], references: [id])

  decidedById String?
  decidedBy   User?     @relation("NegotiationDecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status])
}
